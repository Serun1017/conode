{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022", "DOM"],       // 추가: 브라우저 DOM API 인식
    "jsx": "react",                 // 추가: React JSX 문법 해석
    "target": "ES2022",
    "outDir": "out",
    "rootDir": "src",
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true            // 권장: 외부 라이브러리 타입 검사 생략으로 빌드 속도 향상
  },
  "exclude": [
    "node_modules",
    ".vscode-test"
  ]
}